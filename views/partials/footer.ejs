</style>

<script>
    // ============================================
    // AI CHAT WIDGET - COHERE API INTEGRATION
    // COMPASSIONATE CAPITALISM & BLACK WALL STREET
    // ============================================
    
    (function() {
        const chatButton = document.getElementById('aiChatButton');
        const chatModal = document.getElementById('aiChatModal');
        const closeChat = document.getElementById('closeChat');
        const sendButton = document.getElementById('sendMessage');
        const chatInput = document.getElementById('chatInput');
        const chatMessages = document.getElementById('chatMessages');
        const notificationBadge = document.getElementById('notificationBadge');
        
        let isTyping = false;
        let conversationHistory = [];
        
        // Load saved conversation history from localStorage
        function loadConversationHistory() {
            const saved = localStorage.getItem('cc_chat_history');
            if (saved) {
                try {
                    conversationHistory = JSON.parse(saved);
                    // Display saved messages
                    conversationHistory.forEach(msg => {
                        addMessageToUI(msg.content, msg.role);
                    });
                } catch(e) {
                    console.error('Error loading history:', e);
                }
            }
        }
        
        // Save conversation history to localStorage
        function saveConversationHistory(role, content) {
            conversationHistory.push({ role, content });
            // Keep only last 50 messages to avoid storage limits
            if (conversationHistory.length > 50) {
                conversationHistory = conversationHistory.slice(-50);
            }
            localStorage.setItem('cc_chat_history', JSON.stringify(conversationHistory));
        }
        
        function toggleChat() {
            if (chatModal) {
                chatModal.classList.toggle('active');
                if (chatModal.classList.contains('active')) {
                    setTimeout(() => chatInput.focus(), 100);
                    if (notificationBadge) notificationBadge.style.display = 'none';
                }
            }
        }
        
        function closeChatModal() {
            if (chatModal) chatModal.classList.remove('active');
        }
        
        if (chatButton) {
            chatButton.addEventListener('click', (e) => {
                e.preventDefault();
                toggleChat();
            });
        }
        
        if (closeChat) {
            closeChat.addEventListener('click', (e) => {
                e.preventDefault();
                closeChatModal();
            });
        }
        
        if (chatInput) {
            chatInput.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 80) + 'px';
            });
        }
        
        async function sendMessage() {
            if (!chatInput) return;
            const message = chatInput.value.trim();
            if (!message || isTyping) return;
            
            // Add user message to UI
            addMessageToUI(message, 'user');
            saveConversationHistory('user', message);
            
            // Clear input
            chatInput.value = '';
            chatInput.style.height = 'auto';
            
            // Show typing indicator
            showTypingIndicator();
            isTyping = true;
            
            try {
                // Call the backend Cohere API with restricted scope
                const response = await fetch('/api/chat/send', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({ 
                        message: message,
                        conversationHistory: conversationHistory.filter(m => m.role !== 'bot' || m.role !== 'user' ? true : false).slice(-20)
                    })
                });
                
                let reply;
                if (response.ok) {
                    const data = await response.json();
                    if (data.success) {
                        reply = data.reply;
                    } else {
                        reply = getRestrictedFallbackResponse(message);
                    }
                } else {
                    // Fallback for network errors
                    reply = getRestrictedFallbackResponse(message);
                }
                
                hideTypingIndicator();
                addMessageToUI(reply, 'bot');
                saveConversationHistory('bot', reply);
                
            } catch (error) {
                console.error('Chat API Error:', error);
                hideTypingIndicator();
                const errorReply = "I'm having trouble connecting to the AI service. Please ensure the server is running. Meanwhile, I can still help with basic questions about Compassionate Capitalism and Black Wall Street.";
                addMessageToUI(errorReply, 'bot');
                saveConversationHistory('bot', errorReply);
            } finally {
                isTyping = false;
            }
        }
        
        // Restricted fallback responses for Compassionate Capitalism & Black Wall Street ONLY
        function getRestrictedFallbackResponse(message) {
            const lowerMessage = message.toLowerCase();
            
            // Comprehensive response map for Compassionate Capitalism & Black Wall Street
            const responses = {
                'what is compassionate capitalism|what is cc|compassionate capitalism': 'Compassionate Capitalism is an economic framework that combines free market principles with social responsibility. It focuses on ethical business practices, wealth redistribution, community investment, and sustainable development. Unlike traditional capitalism, Compassionate Capitalism prioritizes people and planet alongside profit.',
                
                'black wall street|black wall street history|greenwood|tulsa': 'Black Wall Street was the nickname for the Greenwood District in Tulsa, Oklahoma - one of the most prosperous African American communities in US history (early 1900s). It had over 600 Black-owned businesses, hospitals, schools, and theaters. In 1921, it was destroyed in the Tulsa Race Massacre, one of the worst acts of racial violence in American history. Today, Black Wall Street represents economic empowerment, entrepreneurship, and rebuilding Black wealth.',
                
                'services|what services do you offer|offer': 'We offer: 1) Investment advisory for ethical ventures, 2) Business consulting for minority entrepreneurs, 3) Educational programs on financial literacy, 4) Community development initiatives, 5) Black Wall Street historical preservation, 6) Wealth building workshops.',
                
                'invest|investment|investing': 'Compassionate Capitalism investments focus on: Community Development Financial Institutions (CDFIs), minority-owned businesses, sustainable enterprises, affordable housing projects, educational initiatives, and Black Wall Street revitalization programs. Minimum investments typically start at $1,000 for community bonds.',
                
                'business|entrepreneur|startup': 'We support entrepreneurs through: 1) Mentorship programs, 2) Access to capital, 3) Business planning assistance, 4) Networking events, 5) Marketing support, 6) Legal and accounting guidance. Join our Black Wall Street Business Alliance for monthly workshops.',
                
                'wealth|build wealth|financial literacy': 'Key wealth-building strategies in Compassionate Capitalism: 1) Invest in appreciating assets, 2) Create multiple income streams, 3) Build business equity, 4) Participate in cooperative economics, 5) Support Black-owned banks and CDFIs, 6) Generational wealth planning through trusts and estates.',
                
                'contact|support|email|phone': 'Contact us: 📞 Phone: +1 (345) 909-6565, 📧 Email: support@compassionatecapitalism.com, 🏢 Address: 503 Old Buffalo Street, Northwest #205, New York, NY 3087. Hours: Monday-Friday 9 AM - 6 PM EST.',
                
                'thank|thanks|appreciate': "You're welcome! Is there anything else about Compassionate Capitalism or Black Wall Street I can help you with?",
                
                'community|cooperative|co-op': 'Cooperative economics (Ujamaa) is a core principle of Compassionate Capitalism. We promote: Worker cooperatives, community land trusts, rotating savings circles (ROSCAs), collective buying power, and community investment funds. These models build sustainable Black wealth.',
                
                'education|learn|course': 'Our educational offerings include: 1) Free weekly webinars on financial literacy, 2) Paid certification in Compassionate Capitalism, 3) Black Wall Street history courses, 4) Entrepreneurship bootcamps, 5) Investment workshops. Visit our Education page for schedules.'
            };
            
            // Check for matches
            for (const [pattern, response] of Object.entries(responses)) {
                if (new RegExp(pattern, 'i').test(lowerMessage)) {
                    return response;
                }
            }
            
            // Default restricted response
            return "I can only provide information about Compassionate Capitalism and Black Wall Street economic empowerment. Please ask me about:\n\n• 📚 The history of Black Wall Street\n• 💼 Business development strategies\n• 📈 Ethical investment principles\n• 🤝 Community economic empowerment\n• 🏦 Financial literacy and wealth building\n• 🌟 Black business success stories\n\nWhat would you like to know?";
        }
        
        function addMessageToUI(text, role) {
            if (!chatMessages) return;
            
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${role === 'user' ? 'sent' : 'received'}`;
            const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            // Format message with line breaks
            const formattedText = text.replace(/\n/g, '<br>');
            
            messageDiv.innerHTML = `
                <div class="message-content">
                    <p>${formattedText}</p>
                    <span class="message-time">${time}</span>
                </div>
            `;
            
            chatMessages.appendChild(messageDiv);
            scrollToBottom();
        }
        
        function showTypingIndicator() {
            if (!chatMessages) return;
            const typingDiv = document.createElement('div');
            typingDiv.className = 'message received';
            typingDiv.id = 'typingIndicator';
            typingDiv.innerHTML = `<div class="message-content"><div class="typing-indicator"><span></span><span></span><span></span></div></div>`;
            chatMessages.appendChild(typingDiv);
            scrollToBottom();
        }
        
        function hideTypingIndicator() {
            const indicator = document.getElementById('typingIndicator');
            if (indicator) indicator.remove();
        }
        
        function scrollToBottom() {
            if (chatMessages) {
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }
        }
        
        // Event listeners
        if (sendButton) sendButton.addEventListener('click', sendMessage);
        if (chatInput) {
            chatInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });
        }
        
        // Option buttons
        document.querySelectorAll('.option-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const question = btn.getAttribute('data-question');
                if (question && chatInput) {
                    chatInput.value = question;
                    sendMessage();
                }
            });
        });
        
        // Close modal when clicking outside
        document.addEventListener('click', (e) => {
            if (chatModal && chatModal.classList.contains('active')) {
                if (!chatModal.contains(e.target) && !chatButton.contains(e.target)) {
                    closeChatModal();
                }
            }
        });
        
        // Load conversation history on startup
        loadConversationHistory();
        
        // Show notification badge for first-time visitors
        setTimeout(() => {
            const hasVisited = localStorage.getItem('cc_chat_visited');
            if (!hasVisited && notificationBadge) {
                notificationBadge.style.display = 'flex';
                localStorage.setItem('cc_chat_visited', 'true');
            } else if (notificationBadge) {
                notificationBadge.style.display = 'none';
            }
        }, 2000);
    })();
    
    // ============================================
    // FOOTER JAVASCRIPT
    // ============================================
    
    // Set current year
    const yearSpan = document.getElementById('currentYear');
    if (yearSpan) yearSpan.innerHTML = new Date().getFullYear();
    
    // Scroll to top button
    const scrollBtn = document.getElementById('scrollToTop');
    if (scrollBtn) {
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) scrollBtn.classList.add('show');
            else scrollBtn.classList.remove('show');
        });
        scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
    
    // Newsletter form
    const newsletterForm = document.getElementById('footerNewsletterForm');
    if (newsletterForm) {
        newsletterForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const input = newsletterForm.querySelector('.newsletter-input');
            const email = input.value;
            if (email && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                alert(`Thank you for subscribing to Compassionate Capitalism updates! We'll send insights to: ${email}`);
                input.value = '';
            } else if (email) {
                alert('Please enter a valid email address.');
            }
        });
    }
    
    // Smooth scroll for footer links
    document.querySelectorAll('.footer-links a, .footer-legal a').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if (href && href.startsWith('#')) {
                e.preventDefault();
                const target = document.querySelector(href);
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            }
        });
    });
</script>