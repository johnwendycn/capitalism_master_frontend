}

.lightning-bread-4 svg polyline {
    animation: breadStrike4 0.5s ease-out forwards;
}

/* Lightning Keyframes */
@keyframes breadFlash1 {
    0%, 92%, 94%, 100% { opacity: 0; transform: translateX(-30px); }
    93% { opacity: 1; transform: translateX(0); }
}

@keyframes breadFlash2 {
    0%, 94%, 96%, 100% { opacity: 0; transform: translateX(30px); }
    95% { opacity: 1; transform: translateX(0); }
}

@keyframes breadFlash3 {
    0%, 96%, 98%, 100% { opacity: 0; transform: scale(0.8); }
    97% { opacity: 1; transform: scale(1); }
}

@keyframes breadFlash4 {
    0%, 90%, 92%, 100% { opacity: 0; transform: translateY(20px); }
    91% { opacity: 1; transform: translateY(0); }
}

@keyframes breadStrike1 {
    0% { stroke-dashoffset: 500; stroke-width: 2; }
    50% { stroke-width: 4; }
    100% { stroke-dashoffset: 0; stroke-width: 2; }
}

@keyframes breadStrike2 {
    0% { stroke-dashoffset: 500; stroke-width: 2; }
    60% { stroke-width: 5; }
    100% { stroke-dashoffset: 0; stroke-width: 2; }
}

@keyframes breadStrike3 {
    0% { stroke-dashoffset: 500; stroke-width: 2; }
    40% { stroke-width: 4; }
    100% { stroke-dashoffset: 0; stroke-width: 2; }
}

@keyframes breadStrike4 {
    0% { stroke-dashoffset: 300; stroke-width: 2; }
    50% { stroke-width: 3; }
    100% { stroke-dashoffset: 0; stroke-width: 2; }
}

/* Glow effect */
.breadcrumbs-lightning svg polyline {
