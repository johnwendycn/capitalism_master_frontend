<<style>
    /* ============================================
       PROFESSIONAL VR ECOSYSTEM - CLEAN WHITE BACKGROUND
       Single Color Scheme: #2563EB (Modern Blue)
       Inspired by MiroTalk Design Language
    ============================================ */
    
    /* Main Section - Pure White Background */
    #rs-courses-2 {
        position: relative;
        width: 100%;
        background: #ffffff;
        padding: 80px 0;
        overflow: hidden;
    }
    
    /* Subtle animated lighting effect - very refined */
    #rs-courses-2::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        background: radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.02) 0%, transparent 60%),
                    radial-gradient(circle at 85% 70%, rgba(37, 99, 235, 0.015) 0%, transparent 60%);
        animation: subtlePulse 8s ease-in-out infinite;
        z-index: 0;
    }
    
    @keyframes subtlePulse {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
    }
    
    /* Section Title */
    .sec-title-2 {
        text-align: center;
        margin-bottom: 50px;
        position: relative;
        z-index: 2;
    }
    
    .sec-title-2 h2 {
        font-size: 42px;
        font-weight: 700;
        color: #1a1a2e;
        letter-spacing: -0.5px;
        position: relative;
        display: inline-block;
        margin-bottom: 0;
    }
    
    .sec-title-2 h2::after {
        content: '';
        position: absolute;
        bottom: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: #2563EB;
        border-radius: 3px;
    }
    
    .view-more {
        margin-top: 25px;
    }
    
    .view-more a {
        color: #2563EB;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    
    .view-more a:hover {
        gap: 10px;
        color: #1d4ed8;
    }
    
    /* Filter Buttons - Clean & Professional */
    .gridFilter {
        text-align: center;
        margin-bottom: 50px;
        position: relative;
        z-index: 2;
    }
    
    .gridFilter button {
        background: transparent;
        border: 1px solid #e2e8f0;
        padding: 8px 24px;
        margin: 5px 6px;
        border-radius: 40px;
        font-weight: 500;
        font-size: 13px;
        transition: all 0.25s ease;
        cursor: pointer;
        color: #4a5568;
    }
    
    .gridFilter button.active,
    .gridFilter button:hover {
        background: #2563EB;
        border-color: #2563EB;
        color: #ffffff;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
    }
    
    /* VR Card - Professional, Clean, One Color */
    .vr-card {
        transition: all 0.35s cubic-bezier(0.2, 0, 0, 1);
        background: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 30px;
        position: relative;
        border: 1px solid #eef2f6;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }
    
    .vr-card:hover {
        transform: translateY(-6px);
        border-color: #2563EB;
        box-shadow: 0 20px 35px -12px rgba(37, 99, 235, 0.15);
    }
    
    /* Icon Section - Single Color */
    .vr-icon {
    background: linear-gradient(135deg, #062466 0%, #051d44 25%, #1D4ED8 50%, #030811 75%, #3B82F6 100%);
    background-size: 200% 200%;
    text-align: center;
    padding: 40px 20px;
    position: relative;
    transition: all 0.3s;
    animation: vrGradientShift 4s ease infinite, vrFloat 3s ease-in-out infinite;
}

/* Animated gradient shift for VR effect */
@keyframes vrGradientShift {
    0% {
        background-position: 0% 50%;
    }
    50% {
        background-position: 100% 50%;
    }
    100% {
        background-position: 0% 50%;
    }
}

/* Floating animation for VR movement */
@keyframes vrFloat {
    0% {
        transform: translateY(0px);
    }
    50% {
        transform: translateY(-6px);
    }
    100% {
        transform: translateY(0px);
    }
}

/* Hover effect - enhanced VR movement */
.vr-card:hover .vr-icon {
    animation: vrGradientShift 2s ease infinite, vrPulse 0.6s ease-in-out;
    background-size: 200% 200%;
}

@keyframes vrPulse {
    0% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.02);
    }
    100% {
        transform: scale(1);
    }
}

/* Icon 3D rotation on hover */
.vr-icon i {
    font-size: 56px;
    color: #ffffff;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
    animation: vrIconGlow 3s ease-in-out infinite;
}

.vr-card:hover .vr-icon i {
    transform: rotateY(180deg) scale(1.1);
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
}

@keyframes vrIconGlow {
    0%, 100% {
        filter: drop-shadow(0 0 2px rgba(255, 255, 255, 0.3));
    }
    50% {
        filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.6));
    }
}

/* Ripple effect behind icon */
.vr-icon::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.15), transparent 70%);
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0);
    animation: vrRipple 3s ease-in-out infinite;
    pointer-events: none;
}

@keyframes vrRipple {
    0% {
        transform: translate(-50%, -50%) scale(0.5);
        opacity: 0.5;
    }
    50% {
        transform: translate(-50%, -50%) scale(1.2);
        opacity: 0;
    }
    100% {
        transform: translate(-50%, -50%) scale(0.5);
        opacity: 0;
    }
}

/* Subtle rotation for the entire card icon area */
.vr-card:hover .vr-icon {
    animation: vrGradientShift 2s ease infinite, vrCardboardTilt 0.4s ease-out forwards;
}

@keyframes vrCardboardTilt {
    0% {
        transform: perspective(500px) rotateX(0deg) rotateY(0deg);
    }
    100% {
        transform: perspective(500px) rotateX(2deg) rotateY(4deg);
    }
}

/* Optional: Remove the tilt on mouse leave for smoothness */
.vr-card .vr-icon {
    transition: transform 0.3s ease;
}
    
    .vr-card:hover .vr-icon {
        background: #1F3A93;
    }
    
    .vr-icon i {
        font-size: 56px;
        color: #ffffff;
        transition: transform 0.3s;
    }
    
    .vr-card:hover .vr-icon i {
        transform: scale(1.02);
