<script>
    (function() {
        // Get modal elements
        var modal = document.getElementById('vr-video-modal');
        var playBtn = document.querySelector('#rs-video-advanced .popup-vimeo');
        var closeBtn = document.querySelector('.vr-modal-close');
        var iframe = document.getElementById('vimeo-player');
        var originalSrc = iframe ? iframe.src : '';

        // Function to open modal with animation and auto-play
        function openModal() {
            if (modal) {
                // Add show class to trigger animations
                modal.classList.add('show');
                document.body.style.overflow = 'hidden';
                
                // Add lightning flash effect on the video section
                var videoDiv = document.querySelector('#rs-video-advanced .rs-video');
                if (videoDiv) {
                    videoDiv.style.transition = 'all 0.2s';
                    videoDiv.style.boxShadow = '0 0 70px rgba(0, 255, 255, 0.9), 0 0 120px rgba(255, 0, 255, 0.7)';
                    setTimeout(function() { 
                        if(videoDiv) videoDiv.style.boxShadow = ''; 
                    }, 500);
                }
                
                // Auto-play the video when modal opens
                if (iframe) {
                    // Extract video ID and build autoplay URL
                    var videoId = '1118159726';
                    iframe.src = 'https://player.vimeo.com/video/' + videoId + '?autoplay=1&loop=0&title=0&byline=0&portrait=0&badge=0&color=00ffff&background=0';
                }
            }
        }

        // Function to close modal with animation and stop video
        function closeModal() {
            if (modal) {
                // Remove show class to trigger closing animations
                modal.classList.remove('show');
                document.body.style.overflow = '';
                
                // Stop video when closing (reset iframe src)
                if (iframe) {
                    iframe.src = 'https://player.vimeo.com/video/1118159726?autoplay=0&loop=0&title=0&byline=0&portrait=0&badge=0&color=00ffff&background=0';
                }
            }
        }

        // Event listeners
        if (playBtn) {
            playBtn.addEventListener('click', function(e) {
                e.preventDefault();
                openModal();
            });
        }

        if (closeBtn) {
            closeBtn.addEventListener('click', closeModal);
        }

        // Close modal when clicking outside the modal container
        window.addEventListener('click', function(event) {
            if (modal && modal.classList.contains('show')) {
                // Check if click is on the overlay (not on content)
                if (event.target === modal || event.target.classList.contains('vr-modal-overlay')) {
                    closeModal();
                }
            }
        });

        // Close on Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape' && modal && modal.classList.contains('show')) {
                closeModal();
            }
        });

        // Lightning randomizer for bolts
        var bolts = document.querySelectorAll('#rs-video-advanced .lightning-bolt');
        function randomizeBolts() {
            bolts.forEach(function(bolt) {
                var randomDur = (Math.random() * 1.8 + 0.8).toFixed(2);
                bolt.style.animationDuration = randomDur + 's';
            });
        }
        if (bolts.length) {
            setInterval(randomizeBolts, 4000);
            randomizeBolts();
        }

        // Spark effect on mouse move
        var rsVideo = document.querySelector('#rs-video-advanced .rs-video');
        if (rsVideo) {
            rsVideo.addEventListener('mousemove', function(e) {
                var rect = this.getBoundingClientRect();
                var x = e.clientX - rect.left;
                var y = e.clientY - rect.top;
                var spark = document.createElement('div');
                spark.style.position = 'absolute';
                spark.style.left = x + 'px';
                spark.style.top = y + 'px';
                spark.style.width = '8px';
                spark.style.height = '8px';
                spark.style.background = 'radial-gradient(circle, cyan, magenta)';
                spark.style.borderRadius = '50%';
                spark.style.filter = 'blur(3px)';
                spark.style.pointerEvents = 'none';
                spark.style.zIndex = '999';
                spark.style.opacity = '0.8';
                spark.style.boxShadow = '0 0 15px cyan, 0 0 25px magenta';
                spark.style.animation = 'rs-fadeOutSpark 0.5s forwards';
                this.appendChild(spark);
                setTimeout(function() { if(spark && spark.remove) spark.remove(); }, 500);
            });

            // 3D tilt effect
            rsVideo.addEventListener('mousemove', function(ev) {
                var rect = this.getBoundingClientRect();
                var centerX = rect.left + rect.width / 2;
                var centerY = rect.top + rect.height / 2;
                var deltaX = (ev.clientX - centerX) / 30;
                var deltaY = (ev.clientY - centerY) / 30;
                this.style.transform = 'perspective(1200px) rotateY(' + (deltaX * 0.8) + 'deg) rotateX(' + (-deltaY * 0.6) + 'deg) scale(1.01)';
            });
            rsVideo.addEventListener('mouseleave', function() {
                this.style.transform = 'perspective(1200px) rotateY(0deg) rotateX(0deg) scale(1)';
                this.style.transition = 'transform 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1)';
                var self = this;
                setTimeout(function() { if(self) self.style.transition = ''; }, 400);
            });
        }
    })();
</script>
